                        return <th key={i} style={{padding:'4px 3px',textAlign:'center',fontWeight:600,color:isWe?'#94a3b8':'#64748b',minWidth:34,background:isWe?'#f1f5f9':'#f8fafc'}}><div style={{fontSize:9}}>{DAYS[dow]}</div><div>{i+1}</div></th>
                      })}
                    </tr>
                  </thead>
                  <tbody>
                    {localMembers.map((member,mi) => (
                      <tr key={member.id} style={{borderBottom:'1px solid #f1f5f9',background:mi%2===0?'#fff':'#fafafa'}}>
                        <td style={{padding:'6px 12px',fontWeight:700,color:'#0f172a',position:'sticky',left:0,background:mi%2===0?'#fff':'#fafafa',whiteSpace:'nowrap'}}>
                          {member.name}{member.team&&<span style={{fontSize:9,color:'#94a3b8',marginLeft:4}}>T{member.team}</span>}
                        </td>
                        {Array(daysInMonth).fill(null).map((_,di) => {
                          const dateStr=formatDate(currentYear,currentMonth,di+1); const shift=getShiftForMemberDate(member.id,dateStr); const tag=shift?getTagByCode(shift.shift_code):null
                          const isToday=new Date().toISOString().slice(0,10)===dateStr
                          return (
                            <td key={di} style={{padding:'2px 2px',textAlign:'center',background:isToday?'#eff6ff':undefined}}>
                              {isAdmin ? (
                                <div onClick={()=>setEditShift({memberId:member.id,date:dateStr,code:shift?.shift_code||''})}
                                  style={{minHeight:24,cursor:'pointer',borderRadius:4,background:tag?tag.color:undefined,color:'#fff',fontWeight:800,fontSize:9,display:'flex',alignItems:'center',justifyContent:'center',opacity:tag?1:0.3}}>
                                  {shift?.shift_code||'+'}
                                </div>
                              ) : (
                                shift&&tag?<span style={{display:'inline-block',background:tag.color,color:'#fff',borderRadius:4,padding:'1px 4px',fontWeight:800,fontSize:9}}>{shift.shift_code}</span>:<span style={{color:'#e2e8f0',fontSize:9}}>·</span>
                              )}
                            </td>
                          )
                        })}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </>
        )}

        {screen === 'my-shifts' && (
          <div>
            <div style={{fontWeight:800,fontSize:18,color:'#0f172a',marginBottom:16}}>👤 My Shifts — {MONTHS[currentMonth]} {currentYear}</div>
            {!myMember ? <div style={s.card}><div style={{color:'#94a3b8'}}>Your profile hasn't been linked yet. Ask your admin.</div></div> : (
              <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(160px,1fr))',gap:10}}>
                {myShifts.filter(s=>s.shift_date.startsWith(${currentYear}-${String(currentMonth+1).padStart(2,'0')})).map(shift => {
                  const tag=getTagByCode(shift.shift_code); const date=new Date(shift.shift_date)
                  return (
                    <div key={shift.id} style={{background:'#fff',borderRadius:12,padding:14,boxShadow:'0 1px 4px rgba(0,0,0,0.07)',borderLeft:4px solid ${tag?.color||'#e2e8f0'}}}>
                      <div style={{fontSize:11,color:'#94a3b8',fontWeight:700,marginBottom:6}}>{DAYS[date.getDay()]} · {date.getDate()} {MONTHS[date.getMonth()]}</div>
                      <div style={{display:'inline-block',background:tag?.color||'#f1f5f9',color:'#fff',borderRadius:6,padding:'3px 10px',fontWeight:800,fontSize:13,marginBottom:6}}>{shift.shift_code}</div>
                      {tag&&<div style={{fontSize:11,color:'#64748b'}}>{tag.start_time} – {tag.end_time}</div>}
                      <button onClick={()=>setSwapModal({myShift:shift})} style={{marginTop:10,width:'100%',padding:'6px',borderRadius:7,border:'1.5px solid #e2e8f0',background:'#f8fafc',color:'#475569',fontSize:11,fontWeight:700,cursor:'pointer'}}>🔄 Request swap</button>
                    </div>
                  )
                })}
              </div>
            )}
          </div>
        )}

        {screen === 'swaps' && (
          <div>
            <div style={{fontWeight:800,fontSize:18,color:'#0f172a',marginBottom:16}}>🔄 Swap Requests</div>
            {pendingForMe.length > 0 && (
              <div style={{marginBottom:24}}>
                <div style={{fontSize:11,fontWeight:800,color:'#ef4444',textTransform:'uppercase',letterSpacing:1,marginBottom:10}}>⚡ Awaiting your response</div>
                {pendingForMe.map(swap => {
                  const reqMember=localMembers.find(m=>m.id===swap.requester_member_id)
                  const reqShift=localShifts.find(s=>s.id===swap.requester_shift_id)
                  const tgtShift=localShifts.find(s=>s.id===swap.target_shift_id)
                  return (
                    <div key={swap.id} style={{...s.card,border:'2px solid #fca5a5'}}>
                      <div style={{fontWeight:700,fontSize:14,marginBottom:12}}><strong>{reqMember?.name}</strong> wants to swap with you</div>
                      <div style={{display:'flex',gap:16,fontSize:13,marginBottom:12}}>
                        <div style={{background:'#f0fdf4',borderRadius:8,padding:'8px 12px',flex:1}}>
                          <div style={{fontSize:10,color:'#94a3b8',fontWeight:700,marginBottom:3}}>THEY GIVE YOU</div>
                          <div style={{fontWeight:700}}>{reqShift?.shift_date}</div>
                          <div style={{fontWeight:800,color:'#166534'}}>{reqShift?.shift_code}</div>
                        </div>
                        <div style={{alignSelf:'center',fontSize:20}}>⇄</div>
                        <div style={{background:'#fef2f2',borderRadius:8,padding:'8px 12px',flex:1}}>
                          <div style={{fontSize:10,color:'#94a3b8',fontWeight:700,marginBottom:3}}>YOU GIVE THEM</div>
                          <div style={{fontWeight:700}}>{tgtShift?.shift_date}</div>
                          <div style={{fontWeight:800,color:'#991b1b'}}>{tgtShift?.shift_code}</div>
                        </div>
                      </div>
                      {swap.message&&<div style={{fontSize:12,color:'#64748b',fontStyle:'italic',marginBottom:12}}>"{swap.message}"</div>}
                      <div style={{display:'flex',gap:8}}>
                        <button onClick={()=>respondToSwap(swap.id,true)} style={{flex:1,padding:9,borderRadius:8,border:'none',background:'#22c55e',color:'#fff',fontWeight:700,cursor:'pointer'}}>✓ Accept</button>
                        <button onClick={()=>respondToSwap(swap.id,false)} style={{flex:1,padding:9,borderRadius:8,border:'none',background:'#ef4444',color:'#fff',fontWeight:700,cursor:'pointer'}}>✗ Decline</button>
                      </div>
                    </div>
                  )
                })}
              </div>
            )}
            {localSwaps.filter(s=>s.requester_member_id===myMember?.id).map(swap => {
              const tgtMember=localMembers.find(m=>m.id===swap.target_member_id)
              return (
                <div key={swap.id} style={{...s.card,opacity:swap.status!=='pending'?0.7:1}}>
                  <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                    <div style={{fontSize:13,fontWeight:700}}>Request to <strong>{tgtMember?.name}</strong></div>
                    <span style={{fontSize:11,fontWeight:700,borderRadius:6,padding:'3px 9px',background:swap.status==='accepted'?'#f0fdf4':swap.status==='declined'?'#fef2f2':'#fefce8',color:swap.status==='accepted'?'#166534':swap.status==='declined'?'#991b1b':'#92400e'}}>{swap.status.toUpperCase()}</span>
                  </div>
                </div>
              )
            })}
            {localSwaps.length===0&&<div style={{...s.card,textAlign:'center',color:'#94a3b8',padding:40}}>No swap requests yet.</div>}
          </div>
        )}

        {screen === 'admin' && isAdmin && (
          <div>
            <div style={{fontWeight:800,fontSize:18,color:'#0f172a',marginBottom:16}}>⚙️ Admin Panel</div>
            <div style={s.card}>
              <div style={{fontWeight:700,fontSize:15,marginBottom:16}}>Add team member</div>
              <div style={{display:'grid',gridTemplateColumns:'1fr 1fr 80px',gap:8,marginBottom:8}}>
                <input value={newMemberName} onChange={e=>setNewMemberName(e.target.value)} placeholder="Full name" style={s.inp}/>
                <input value={newMemberEmail} onChange={e=>setNewMemberEmail(e.target.value)} placeholder="Email (optional)" style={s.inp}/>
                <input value={newMemberTeam} onChange={e=>setNewMemberTeam(e.target.value)} placeholder="Team" style={s.inp}/>
              </div>
              <button onClick={addMember} style={{...s.btn(true,'#22c55e'),marginBottom:16}}>+ Add member</button>
              <div style={{fontWeight:700,fontSize:14,marginBottom:8,marginTop:8}}>Current members ({localMembers.length})</div>
              {localMembers.map(m=>(
                <div key={m.id} style={{display:'flex',gap:8,padding:'8px 0',borderBottom:'1px solid #f1f5f9',fontSize:13}}>
                  <span style={{flex:1,fontWeight:600}}>{m.name}</span>
                  <span style={{color:'#94a3b8'}}>{m.team&&Team ${m.team}}</span>
                  <span style={{color:'#94a3b8'}}>{m.email}</span>
                </div>
              ))}
            </div>
            <div style={s.card}>
              <div style={{fontWeight:700,fontSize:15,marginBottom:16}}>Upload new rota</div>
              <label style={{display:'block',border:'2px dashed #e2e8f0',borderRadius:10,padding:24,textAlign:'center',cursor:'pointer',color:'#94a3b8'}}>
                {uploadLoading?'⏳ Processing...':'📄 Upload PDF or image — AI will extract shifts'}
                <input type="file" accept=".pdf,image/*" style={{display:'none'}} onChange={e=>e.target.files?.[0]&&handleAIUpload(e.target.files[0])}/>
              </label>
            </div>
          </div>
        )}

        {screen === 'settings' && (
          <div>
            <div style={{fontWeight:800,fontSize:18,color:'#0f172a',marginBottom:16}}>🔧 Settings</div>
            <div style={s.card}>
              <div style={{fontWeight:700,fontSize:15,marginBottom:16}}>Calendar view</div>
              <div style={{display:'flex',gap:8}}>
                {[['full','👥 Full rota'],['personal','👤 My shifts only']].map(([v,l])=>(
                  <button key={v} onClick={async()=>{setViewMode(v as any);await supabase.from('profiles').update({settings:{view:v}}).eq('id',profile?.id);showToast('Saved!')}} style={s.btn(viewMode===v,'#3b82f6')}>{l}</button>
                ))}
              </div>
            </div>
            <div style={s.card}>
              <div style={{fontWeight:700,fontSize:15,marginBottom:8}}>Account</div>
              <div style={{fontSize:13,color:'#64748b',marginBottom:4}}>Name: <strong>{profile?.display_name}</strong></div>
              <div style={{fontSize:13,color:'#64748b',marginBottom:16}}>Email: <strong>{profile?.email}</strong></div>
              <button onClick={signOut} style={{...s.btn(true,'#ef4444')}}>Sign out</button>
            </div>
          </div>
        )}
      </div>

      {editShift && (
        <div style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.5)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:200,padding:20}}>
          <div style={{background:'#fff',borderRadius:16,padding:28,width:'100%',maxWidth:360}}>
            <div style={{fontWeight:900,fontSize:18,marginBottom:4}}>Edit Shift</div>
            <div style={{fontSize:13,color:'#64748b',marginBottom:20}}>{localMembers.find(m=>m.id===editShift.memberId)?.name} · {editShift.date}</div>
            <div style={{display:'grid',gridTemplateColumns:'repeat(3,1fr)',gap:8,marginBottom:20}}>
              <button onClick={()=>setEditShift({...editShift,code:''})} style={{...s.btn(!editShift.code,'#94a3b8'),fontSize:12}}>Clear</button>
              {localTags.map(tag=>(
                <button key={tag.id} onClick={()=>setEditShift({...editShift,code:tag.code})}
                  style={{padding:'8px',borderRadius:8,border:2px solid ${editShift.code===tag.code?tag.color:'#e2e8f0'},cursor:'pointer',background:editShift.code===tag.code?tag.color:'#fff',color:editShift.code===tag.code?'#fff':'#475569',fontWeight:700,fontSize:12}}>
                  {tag.code}
                </button>
              ))}
            </div>
            <div style={{display:'flex',gap:8}}>
              <button onClick={()=>setEditShift(null)} style={{flex:1,padding:11,borderRadius:9,border:'1.5px solid #e2e8f0',background:'#fff',color:'#475569',fontWeight:700,cursor:'pointer'}}>Cancel</button>
              <button onClick={saveManualShift} style={{flex:2,padding:11,borderRadius:9,border:'none',background:'#0f172a',color:'#fff',fontWeight:700,cursor:'pointer'}}>Save</button>
            </div>
          </div>
        </div>
      )}

      {swapModal && (
        <div style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.5)',display:'flex',alignItems:'center',justifyContent:'center',zIndex:200,padding:20}}>
          <div style={{background:'#fff',borderRadius:16,padding:28,width:'100%',maxWidth:420}}>
            <div style={{fontWeight:900,fontSize:18,marginBottom:4}}>🔄 Request Swap</div>
            <div style={{fontSize:13,color:'#64748b',marginBottom:20}}>Your shift: <strong>{swapModal.myShift.shift_date}</strong> — <strong>{swapModal.myShift.shift_code}</strong></div>
            <label style={s.label}>Swap with</label>
            <select value={swapTargetMember} onChange={e=>{setSwapTargetMember(e.target.value);setSwapTargetShift('')}} style={s.inp}>
              <option value="">— Select colleague —</option>
              {localMembers.filter(m=>m.id!==myMember?.id).map(m=><option key={m.id} value={m.id}>{m.name}</option>)}
            </select>
            {swapTargetMember && (
              <>
                <label style={s.label}>Their shift to swap</label>
                <select value={swapTargetShift} onChange={e=>setSwapTargetShift(e.target.value)} style={s.inp}>
                  <option value="">— Select their shift —</option>
                  {localShifts.filter(s=>s.member_id===swapTargetMember).map(s=><option key={s.id} value={s.id}>{s.shift_date} — {s.shift_code}</option>)}
                </select>
              </>
            )}
            <label style={s.label}>Message (optional)</label>
            <input value={swapMessage} onChange={e=>setSwapMessage(e.target.value)} placeholder="Reason for swap..." style={s.inp}/>
            <div style={{display:'flex',gap:8}}>
              <button onClick={()=>setSwapModal(null)} style={{flex:1,padding:11,borderRadius:9,border:'1.5px solid #e2e8f0',background:'#fff',color:'#475569',fontWeight:700,cursor:'pointer'}}>Cancel</button>
              <button onClick={submitSwap} disabled={!swapTargetShift} style={{flex:2,padding:11,borderRadius:9,border:'none',background:!swapTargetShift?'#e2e8f0':'#0f172a',color:'#fff',fontWeight:700,cursor:swapTargetShift?'pointer':'default'}}>Send request</button>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
